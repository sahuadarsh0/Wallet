<?xml version="1.0" encoding="utf-8"?>
<!-- Backup / device-transfer rules for API 31+.
     Excludes sensitive DataStore file containing PIN hashes and salts. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="root"
            path="datastore/wallet_preferences.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="root"
            path="datastore/wallet_preferences.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
