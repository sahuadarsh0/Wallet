<?xml version="1.0" encoding="utf-8"?>
<!-- Legacy backup rules for API < 31.
     Excludes all sensitive data: database, images, preferences, and cache. -->
<full-backup-content>
    <exclude domain="root" path="datastore/" />
    <exclude domain="database" path="wallet_database" />
    <exclude domain="database" path="wallet_database-shm" />
    <exclude domain="database" path="wallet_database-wal" />
    <exclude domain="database" path="wallet_database-journal" />
    <exclude domain="file" path="card_images/" />
    <exclude domain="file" path="thumbnails/" />
    <exclude domain="sharedpref" path="storage_prefs.xml" />
    <exclude domain="sharedpref" path="cardvault_keyset_prefs.xml" />
</full-backup-content>
